import type { StateCreator } from "zustand";
import type { SpriteAsset } from "../../types";

export interface SpriteSlice {
  sprites: SpriteAsset[];
  selectedSpriteId: string | null;
  addSprite: (name: string, tilesetId: string) => void;
  addAnimation: (spriteId: string, name: string) => void;
  addFrame: (spriteId: string, animationId: string, tileIndex: number) => void;
  updateFrameDuration: (
    spriteId: string,
    animationId: string,
    frameIndex: number,
    duration: number,
  ) => void;
  removeFrame: (spriteId: string, animationId: string, frameIndex: number) => void;
  setSelectedSpriteId: (spriteId: string | null) => void;
}

type SpriteState = SpriteSlice & {
  saveHistory: () => void;
};

export const createSpriteSlice: StateCreator<
  SpriteState,
  [],
  [],
  SpriteSlice
> = (set, get) => ({
  sprites: [],
  selectedSpriteId: null,

  addSprite: (name, tilesetId) => {
    const newSpriteId = crypto.randomUUID();
    set((state) => ({
      sprites: [
        ...state.sprites,
        { id: newSpriteId, name, animations: [], tilesetId },
      ],
      selectedSpriteId: newSpriteId,
    }));
    get().saveHistory();
  },

  setSelectedSpriteId: (spriteId) => {
    set({ selectedSpriteId: spriteId });
  },

  addAnimation: (spriteId, name) => {
    set((state) => ({
      sprites: state.sprites.map((sprite) =>
        sprite.id === spriteId
          ? {
              ...sprite,
              animations: [
                ...sprite.animations,
                {
                  id: crypto.randomUUID(),
                  name,
                  frames: [],
                  loop: true,
                },
              ],
            }
          : sprite,
      ),
    }));
    get().saveHistory();
  },

  addFrame: (spriteId, animationId, tileIndex) => {
    set((state) => ({
      sprites: state.sprites.map((sprite) =>
        sprite.id === spriteId
          ? {
              ...sprite,
              animations: sprite.animations.map((animation) =>
                animation.id === animationId
                  ? {
                      ...animation,
                      frames: [...animation.frames, { tileIndex, duration: 8 }],
                    }
                  : animation,
              ),
            }
          : sprite,
      ),
    }));
    get().saveHistory();
  },

  updateFrameDuration: (spriteId, animationId, frameIndex, duration) => {
    set((state) => ({
      sprites: state.sprites.map((sprite) =>
        sprite.id === spriteId
          ? {
              ...sprite,
              animations: sprite.animations.map((animation) =>
                animation.id === animationId
                  ? {
                      ...animation,
                      frames: animation.frames.map((frame, currentIndex) =>
                        currentIndex === frameIndex ? { ...frame, duration } : frame,
                      ),
                    }
                  : animation,
              ),
            }
          : sprite,
      ),
    }));
    get().saveHistory();
  },

  removeFrame: (spriteId, animationId, frameIndex) => {
    set((state) => ({
      sprites: state.sprites.map((sprite) =>
        sprite.id === spriteId
          ? {
              ...sprite,
              animations: sprite.animations.map((animation) =>
                animation.id === animationId
                  ? {
                      ...animation,
                      frames: animation.frames.filter(
                        (_, currentIndex) => currentIndex !== frameIndex,
                      ),
                    }
                  : animation,
              ),
            }
          : sprite,
      ),
    }));
    get().saveHistory();
  },
});
